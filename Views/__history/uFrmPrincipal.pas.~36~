unit uFrmPrincipal;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.ExtCtrls, Vcl.Menus, uFrmCadastro, uDM, uFrmMovimentacao,
  Vcl.DBCtrls, Data.DB, Vcl.Grids, Vcl.DBGrids, uService.Produto;

type
  TForm1 = class(TForm)
    pnBotoes: TPanel;
    pnFiltros: TPanel;
    btnInserir: TButton;
    grLista: TDBGrid;
    btnAlterar: TButton;
    pnMenus: TPanel;
    edtPesquisa: TEdit;
    cbxFiltros: TComboBox;
    ckbAtivo: TCheckBox;
    ckbInativo: TCheckBox;
    btnLocalizar: TButton;
    Movimenta誽o: TButton;
    btnDeletar: TButton;
    procedure btnInserirClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure btnAlterarClick(Sender: TObject);
    procedure grListaCellClick(Column: TColumn);
    procedure btnLocalizarClick(Sender: TObject);
    procedure Movimenta誽oClick(Sender: TObject);
    procedure btnDeletarClick(Sender: TObject);
    procedure grListaKeyUp(Sender: TObject; var Key: Word; Shift: TShiftState);
  private
    { Private declarations }
    FSQLOriginal: string;
  public
    { Public declarations }
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}


procedure TForm1.btnDeletarClick(Sender: TObject);
  var
    IDProduto : Integer;
    Service : TProdutoService;
  begin
    Service := TProdutoService.Create;
    IDProduto := dmPrincipal.qrListaProd.FieldByName('ProdutoID').AsInteger;
    Service.Deletar(IDProduto, dmPrincipal.FDConnection1);
    btnLocalizarClick(nil);
  end;

procedure TForm1.btnInserirClick(Sender: TObject);
  var
    formCadastro: TForm2;
  begin
    formCadastro := TForm2.Create(nil);
    formCadastro.ShowModal;
    dmPrincipal.qrListaProd.Refresh;
    btnAlterar.Enabled := False;
  end;

procedure TForm1.btnLocalizarClick(Sender: TObject);
  begin
    dmPrincipal.qrListaProd.Close;
    dmPrincipal.qrListaProd.SQL.Clear;
    dmPrincipal.qrListaProd.SQL.add(FSQLOriginal);
    dmPrincipal.qrListaProd.SQL.Add('WHERE');
    
    
    
    if Trim(edtPesquisa.Text) <> '' then
      begin
  
        case cbxFiltros.ItemIndex of
          0: 
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' p.NOME LIKE :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsString := '%' + Trim(edtPesquisa.Text) + '%';
          end;
          1:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' un.SIGLA LIKE :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsString := '%' + Trim(edtPesquisa.Text) + '%';
          end;
          2:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' p.PRECO_CUSTO = :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsFloat := StrToFloat(edtPesquisa.Text);
          end;
          3:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' p.PRECO_VENDA = :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsFloat := StrToFloat(edtPesquisa.Text);
          end;
          4:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' p.QUANTIDADE = :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsInteger := StrToInt(edtPesquisa.Text);
          end;
          5:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' cat.NOME LIKE :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsString := '%' + Trim(edtPesquisa.Text) + '%';
          end;
          6:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' ma.NOME LIKE :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsString := '%' + Trim(edtPesquisa.Text) + '%';
          end;
          7:
          begin   
            dmPrincipal.qrListaProd.SQL.Add(' f.NOME LIKE :pFiltro');
            dmPrincipal.qrListaProd.ParamByName('pFiltro').AsString := '%' + Trim(edtPesquisa.Text) + '%';
          end;
        end;

      if ckbAtivo.Checked and (ckbInativo.Checked = false) then
        begin
          dmPrincipal.qrListaProd.SQL.Add('and p.ATIVO = ''A''');  
        end
        else if ckbInativo.Checked and (ckbAtivo.Checked = false) then
        begin
          dmPrincipal.qrListaProd.SQL.Add('and p.ATIVO = ''D''');  
        end;
        
      end
      else
      begin
        if ckbAtivo.Checked and (ckbInativo.Checked = false) then
        begin
          dmPrincipal.qrListaProd.SQL.Add(' p.ATIVO = ''A''');  
        end
        else if ckbInativo.Checked and (ckbAtivo.Checked = false) then
        begin
          dmPrincipal.qrListaProd.SQL.Add(' p.ATIVO = ''D''');  
        end
        else
        begin
          dmPrincipal.qrListaProd.SQL.Clear;
          dmPrincipal.qrListaProd.SQL.add(FSQLOriginal);
        end;
      end;

    dmPrincipal.qrListaProd.Open;
  end;

procedure TForm1.btnAlterarClick(Sender: TObject);
var
  formCadastro: TForm2;
begin
  formCadastro := TForm2.Create(nil);
  formCadastro.ProdutoIDEdicao := dmPrincipal.qrListaProd.FieldByName('ProdutoID').AsInteger;
  formCadastro.ShowModal;
  dmPrincipal.qrListaProd.Refresh;
  btnAlterar.Enabled := False;
end;

procedure TForm1.FormCreate(Sender: TObject);
begin
  FSQLOriginal := dmPrincipal.qrListaProd.SQL.Text;
  grLista.DataSource.DataSet.Open;
  btnLocalizarClick(nil);
  if dmPrincipal.qrListaProd.FieldByName('ProdutoID').AsInteger = 0 then
    begin
      btnAlterar.Enabled := False;
    end;
end;

procedure TForm1.grListaCellClick(Column: TColumn);
var
  Service : TProdutoService;
  IDProduto : Integer;
begin
  Service := TProdutoService.Create;
  IDProduto := dmPrincipal.qrListaProd.FieldByName('ProdutoID').AsInteger;
   if IDProduto > 0 then
   begin
     btnAlterar.Enabled := True;
   end;
   if service.RetornaNumeroMovimentacao(IDProduto, dmPrincipal.FDConnection1) > 0 then
    btnDeletar.Enabled := False
   else
    btnDeletar.Enabled := True;
end;

procedure TForm1.grListaKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  grListaCellClick(nil);
end;

procedure TForm1.Movimenta誽oClick(Sender: TObject);
var
  formMovimentacao: TForm3;
begin
  formMovimentacao := TForm3.Create(nil);
  formMovimentacao.show;
end;

end.
