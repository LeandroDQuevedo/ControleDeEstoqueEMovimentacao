unit uFrmMovimentacao;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, FireDAC.Comp.Client, uFrmInformarMovimentacao, Vcl.ExtCtrls, uDM, uService.Produto,
  uModel.Classes, Data.DB, Vcl.Grids, Vcl.DBGrids;

type
  TForm3 = class(TForm)
    pnBotoes: TPanel;
    btnMovimentacao: TButton;
    grListMov: TDBGrid;
    btnDeletarMov: TButton;
    procedure btnMovimentacaoClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure btnDeletarMovClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form3: TForm3;

implementation

{$R *.dfm}

procedure TForm3.btnDeletarMovClick(Sender: TObject);
var
  FProduto : TProduto;
  novaQuantidade : double;
  Service : TProdutoService;
begin
  Service := TProdutoService.Create;
  try
    FProduto := Service.RetornarProduto(dmPrincipal.qrListaMov.FieldByName('ID_PRODUTO').AsInteger);

    if dmPrincipal.qrListaMov.FieldByName('TIPO').AsString = 'Entrada' then
      FProduto.Quantidade := FProduto.Quantidade - dmPrincipal.qrListaMov.FieldByName('QUANTIDADE').AsFloat
    else
      FProduto.Quantidade := FProduto.Quantidade + dmPrincipal.qrListaMov.FieldByName('QUANTIDADE').AsFloat;

    Service.Atualizar(FProduto,dmPrincipal.FDConnection1);
  finally
    Service.Free;
  end;
end;

procedure TForm3.btnMovimentacaoClick(Sender: TObject);
var
  formInforMovimentacao: TForm4;
begin
  formInforMovimentacao := TForm4.Create(nil);
  formInforMovimentacao.ShowModal;
end;

procedure TForm3.FormCreate(Sender: TObject);
begin
  grListMov.DataSource.DataSet.Open;
end;

end.
